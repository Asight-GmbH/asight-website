---
import ManagementCockpit from "./ManagementCockpit.astro";
---
<section class="hero">
  <div class="hero-bg">
    <div class="hero-gradient"></div>
    <div class="hero-grid-pattern"></div>
  </div>
  <div class="container hero-split">
    <div class="hero-text">
      <h1 class="hero-title">
        <span class="hero-headline-top">Termintreu. Qualitätssicher. Lieferfähig.</span>
        <span class="hero-accent">Wir wissen, was Ihr Kunde erwartet<br />und wie Sie es liefern.</span>
      </h1>
      <p class="hero-subtitle">ASIGHT transformiert Shopfloor Daten in echte Entscheidungsgrundlagen. Wir verbessern Prozesse und sichern Ihre Lieferfähigkeit und die Ihrer Lieferanten – für messbare Wertschöpfung ab Tag eins.</p>
      <div class="hero-ctas">
        <a href="https://tidycal.com/asight/beratungstermin-30min" target="_blank" rel="noopener" class="btn btn-primary-gradient">
          Jetzt Potenziale erkennen <span>&rarr;</span>
        </a>
      </div>
    </div>
    <div class="hero-visual">
      <ManagementCockpit />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: auto;
    display: flex;
    align-items: center;
    padding-top: 72px;
    padding-bottom: 0;
    overflow: visible;
    background: var(--c-hero-bg);
    color: var(--c-hero-text);
    z-index: 2;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 50% at 70% 50%, rgba(58,166,185,0.12) 0%, transparent 60%);
  }

  .hero-grid-pattern {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .hero-split {
    position: relative;
    display: grid;
    grid-template-columns: 38% 62%;
    gap: 2rem;
    align-items: center;
    padding: 5rem 0 2rem;
  }

  .hero-text {
    position: relative;
    z-index: 200;
    margin-right: 0;
  }

  .hero-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    color: #fff;
  }

  .hero-headline-top {
    display: block;
    white-space: nowrap;
  }

  .hero-accent {
    background: linear-gradient(135deg, #AFDDE9, #3AA6B9, #2E8A9A);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #8791a1;
    margin-bottom: 2rem;
  }

  .hero-subtitle strong {
    color: #d6dae0;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .hero-trust-signal {
    font-size: 0.85rem;
    font-style: italic;
    color: #4B5F78;
    margin-top: 1.25rem;
    font-weight: 400;
  }

  .btn-primary-gradient {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 1.8rem;
    background: linear-gradient(135deg, #3AA6B9, #2E8A9A);
    color: #fff;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(58,166,185,0.3);
  }

  .btn-primary-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 30px rgba(58,166,185,0.4);
    color: #fff;
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #8791a1;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .cta-link:hover {
    color: #AFDDE9;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 100;
    transform: translateY(20px) scale(1.25);
    margin-left: 0;
  }

  @media (max-width: 1024px) {
    .hero-split {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }

    .hero-text {
      max-width: 100%;
      order: 1;
    }

    .hero-visual {
      order: 2;
    }

    .hero-ctas {
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .hero-ctas {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
