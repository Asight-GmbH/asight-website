---
import { getEntry } from 'astro:content';

interface Props { locale?: string; }
const { locale = 'de' } = Astro.props;

const header = await getEntry('pages', `${locale}/header`);
const { nav_items, cta_text, cta_href } = header?.data ?? {};
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <img src="/assets/logos/asight-wordmark.svg" alt="ASIGHT Consulting" class="logo-img" />
    </a>
    <nav class="nav">
      {(nav_items ?? []).map((item: any) => (
        <a href={item.href} class="nav-link">{item.label}</a>
      ))}
    </nav>
    <div class="header-right">
      <a href={locale === 'de' ? '/en/?lang=en' : '/?lang=de'} class="lang-switch">{locale === 'de' ? 'EN' : 'DE'}</a>
      <a href={cta_href} class="btn btn-primary btn-sm">{cta_text}</a>
    </div>
  </div>
</header>

<style>
  .header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(255,255,255,0.92); backdrop-filter: blur(16px); border-bottom: 1px solid var(--c-border); }
  .header-inner { display: flex; align-items: center; justify-content: space-between; height: 72px; }
  .logo { display: flex; align-items: center; text-decoration: none; }
  .logo-img { height: 28px; width: auto; margin-left: -2px; }
  .nav { display: flex; gap: 2rem; }
  .nav-link { font-size: 0.875rem; font-weight: 500; color: var(--c-text-secondary); text-decoration: none; transition: color var(--t-fast); }
  .nav-link:hover { color: var(--c-accent); }
  .header-right { display: flex; align-items: center; gap: 1rem; }
  .lang-switch { font-size: 0.8rem; font-weight: 600; color: var(--c-text-muted); text-decoration: none; padding: 0.3rem 0.6rem; border: 1px solid var(--c-border); border-radius: 4px; transition: all 0.2s ease; }
  .lang-switch:hover { color: var(--c-accent); border-color: var(--c-accent); }
  .btn-sm { padding: 0.55rem 1.25rem; font-size: 0.825rem; }
  @media (max-width: 768px) { .nav { display: none; } }
</style>
