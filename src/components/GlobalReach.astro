---
import { getEntry } from 'astro:content';

interface Props { locale?: string; }
const { locale = 'de' } = Astro.props;

const data = await getEntry('pages', `${locale}/globalreach`);
const fallback = {
  map_label: 'GLOBALE REICHWEITE',
  map_subtitle: 'Erfahrungs-Fokus',
  locations: [
    { name: 'USA',         x: 22,  y: 50 },
    { name: 'Deutschland', x: 51,  y: 38 },
    { name: 'Polen',       x: 55,  y: 32 },
    { name: 'Slowakei',    x: 54.5,y: 39 },
  ],
  cards: [
    {
      icon: 'team',
      title: 'Interkulturelles Projektmanagement',
      description: 'Leitung internationaler Teams und Lieferantensteuerung vor Ort.',
    },
    {
      icon: 'globe',
      title: 'US-Markt-Expertise',
      description: 'Langjährige Erfahrung im Aufbau und Betrieb von Produktionsstandorten in Nordamerika.',
    },
  ],
};

const { map_label, map_subtitle, locations, cards } = (data?.data ?? fallback) as typeof fallback;

const icons: Record<string, string> = {
  team: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  globe: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>`,
};
---

<section id="reichweite" class="global-reach">
  <div class="container">
    <div class="reach-grid">
      <!-- Map card -->
      <div class="map-card">
        <div class="map-label">{map_label}</div>
        <div class="map-subtitle">{map_subtitle}</div>
        <div class="map-wrapper">
          <img src="/assets/world-map-final.svg" alt="" class="world-map" />

          {locations.map((loc: any) => (
            <div class={`map-pin map-pin--label-${loc.label_position ?? 'top'}`} style={`left: ${loc.x}%; top: ${loc.y}%;`}>
              <span class="pin-glow"></span>
              <span class="pin-dot"></span>
              <span class="pin-pulse"></span>
              <span class="pin-label">{loc.name}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Info cards -->
      <div class="info-cards">
        {cards.map((card: any) => (
          <div class="info-card">
            <div class="info-icon" set:html={icons[card.icon] ?? icons.globe} />
            <div class="info-content">
              <h3 class="info-title">{card.title}</h3>
              <p class="info-text">{card.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .global-reach {
    background: #11161d;
    padding: 0 0 5rem;
  }

  .reach-grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr;
    gap: 1.5rem;
  }

  /* === Map Card === */
  .map-card {
    position: relative;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 2rem 2rem 2.5rem;
    overflow: hidden;
  }

  .map-label {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: #AFDDE9;
    margin-bottom: 0.25rem;
  }

  .map-subtitle {
    font-size: 0.95rem;
    color: #8791a1;
    margin-bottom: 1.5rem;
  }

  .map-wrapper {
    position: relative;
    width: 100%;
    /* Crop Antarctica (bottom ~12% of the SVG) */
    aspect-ratio: 4378 / 2150;
    overflow: hidden;
  }

  .world-map {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: auto;
    display: block;
  }

  /* === Pins === */
  .map-pin {
    position: absolute;
    pointer-events: none;
    width: 0;
    height: 0;
  }

  .pin-label {
    position: absolute;
    font-size: 0.75rem;
    font-weight: 600;
    color: #d6dae0;
    background: rgba(58,166,185,0.15);
    border: 1px solid rgba(175,221,233,0.25);
    padding: 2px 8px;
    border-radius: 4px;
    white-space: nowrap;
    cursor: default;
    pointer-events: auto;
    transition: transform 0.25s ease, background 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    transform-origin: center;
  }

  .pin-label:hover {
    background: rgba(58,166,185,0.30);
    border-color: rgba(175,221,233,0.55);
    box-shadow: 0 6px 20px rgba(58,166,185,0.35);
  }

  /* Scale per label-position so the anchor side stays put */
  .map-pin--label-top .pin-label:hover    { transform: translateX(-50%) scale(1.12); }
  .map-pin--label-bottom .pin-label:hover { transform: translateX(-50%) scale(1.12); }
  .map-pin--label-left .pin-label:hover   { transform: translateY(-50%) scale(1.12); }
  .map-pin--label-right .pin-label:hover  { transform: translateY(-50%) scale(1.12); }

  /* Label positioning variants */
  .map-pin--label-top .pin-label {
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
  }
  .map-pin--label-bottom .pin-label {
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
  }
  .map-pin--label-left .pin-label {
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
  }
  .map-pin--label-right .pin-label {
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
  }

  /* Soft radial glow halo (matches impact-card hover effect) */
  .pin-glow {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: radial-gradient(circle, #3AA6B9 0%, transparent 70%);
    filter: blur(14px);
    opacity: 0.7;
    pointer-events: none;
    z-index: 0;
  }

  .pin-dot {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-50%, -50%);
    width: 12px;
    height: 12px;
    background: #3AA6B9;
    border: 2px solid #AFDDE9;
    border-radius: 50%;
    z-index: 2;
    box-shadow: 0 0 12px rgba(58,166,185,0.6);
  }

  .pin-pulse {
    position: absolute;
    top: 0;
    left: 0;
    width: 12px;
    height: 12px;
    background: #3AA6B9;
    border-radius: 50%;
    animation: pinPulse 2s ease-out infinite;
    z-index: 1;
  }

  @keyframes pinPulse {
    0%   { transform: translate(-50%, -50%) scale(1);   opacity: 0.6; }
    100% { transform: translate(-50%, -50%) scale(2.8); opacity: 0;   }
  }

  /* === Info Cards === */
  .info-cards {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 1.5rem;
  }

  .info-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    align-items: start;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 1.75rem;
  }

  .info-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(58,166,185,0.1);
    color: #AFDDE9;
    flex-shrink: 0;
  }

  .info-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #d6dae0;
    margin: 0 0 0.5rem;
  }

  .info-text {
    font-size: 0.9rem;
    color: #8791a1;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 900px) {
    .reach-grid {
      grid-template-columns: 1fr;
    }
    .info-cards {
      grid-template-rows: auto auto;
    }
  }
</style>
