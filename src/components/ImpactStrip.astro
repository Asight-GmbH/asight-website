---
import { getEntry } from 'astro:content';

interface Props { locale?: string; }
const { locale = 'de' } = Astro.props;

const impact = await getEntry('pages', `${locale}/impact`);
const { headline, subline, cards } = impact?.data ?? {};

const colorClasses = ['teal', 'light', 'blue', 'dark'];
const icons = [
  `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M7 12h10"/><path d="M10 18h4"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
];
---
<section class="impact-strip">
  <div class="container">
    <div class="impact-header">
      <h2 class="impact-headline">{headline}</h2>
      <p class="impact-subline">{subline}</p>
    </div>
    <div class="impact-cards">
      {(cards ?? []).map((card: any, i: number) => (
        <div class={`impact-card impact-card--${colorClasses[i]}`}>
          <div class="impact-icon" set:html={icons[i]} />
          <h3 class="impact-title">{card.title}</h3>
          <p class="impact-subtitle">{card.subtitle}</p>
          <p class="impact-text">{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .impact-strip {
    background: #f6f7f8;
    padding: 5rem 0;
    position: relative;
  }

  .impact-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .impact-headline {
    font-size: clamp(1.75rem, 3vw, 2rem);
    font-weight: 700;
    color: #1b222c;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .impact-subline {
    font-size: 1.1rem;
    font-weight: 400;
    color: #4B5F78;
    margin: 0;
  }

  .impact-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .impact-card {
    position: relative;
    padding: 2rem;
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.8);
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 4px 24px rgba(0,0,0,0.04);
  }

  .impact-card::before {
    content: '';
    position: absolute;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0.5;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .impact-card--teal::before {
    top: -50px;
    right: -50px;
    background: radial-gradient(circle, #3AA6B9 0%, transparent 70%);
  }

  .impact-card--light::before {
    top: -50px;
    right: -50px;
    background: radial-gradient(circle, #AFDDE9 0%, transparent 70%);
  }

  .impact-card--blue::before {
    top: -50px;
    right: -50px;
    background: radial-gradient(circle, #4B5F78 0%, transparent 70%);
  }

  .impact-card--dark::before {
    top: -50px;
    right: -50px;
    background: radial-gradient(circle, #454F5E 0%, transparent 70%);
  }

  .impact-card:hover {
    background: rgba(255,255,255,0.8);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .impact-card:hover::before {
    opacity: 0.7;
  }

  .impact-icon {
    position: relative;
    color: #3AA6B9;
    opacity: 0.9;
    margin-bottom: 0.75rem;
  }

  .impact-title {
    position: relative;
    font-size: 1.15rem;
    font-weight: 700;
    color: #1b222c;
    margin-bottom: 0.35rem;
    letter-spacing: -0.01em;
  }

  .impact-subtitle {
    position: relative;
    font-size: 0.85rem;
    font-weight: 600;
    color: #3AA6B9;
    margin-bottom: 0.75rem;
  }

  .impact-card--light .impact-subtitle { color: #AFDDE9; filter: brightness(0.7); }
  .impact-card--blue .impact-subtitle { color: #4B5F78; }
  .impact-card--dark .impact-subtitle { color: #454F5E; }

  .impact-text {
    position: relative;
    font-size: 0.85rem;
    color: #4B5F78;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 1100px) {
    .impact-cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .impact-strip { padding: 3rem 0; }
    .impact-cards { grid-template-columns: 1fr; gap: 1rem; }
    .impact-card { padding: 1.5rem; }
  }
</style>
