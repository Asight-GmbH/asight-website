---
import { getEntry } from 'astro:content';

interface Props { locale?: string; }
const { locale = 'de' } = Astro.props;

const sp = await getEntry('pages', `${locale}/socialproof`);
const { headline, client_label, transition_text, transition_emphasis, oem_label } = sp?.data ?? {};
---
<section class="social-proof">
  <div class="container">
    <!-- Headline -->
    <h2 id="reichweite" class="social-proof-headline">{headline}</h2>

    <!-- Überleitung -->
    <p class="transition-text">
      {transition_text}<br />
      <em>{transition_emphasis}</em>
    </p>
  </div>
</section>

<style>
  .social-proof {
    background: #11161d;
    padding: 5rem 0;
    position: relative;
  }

  .social-proof-headline {
    text-align: center;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #d6dae0;
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
  }

  .section-label {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: #4B5F78;
    margin-bottom: 2rem;
  }

  .section-label::before,
  .section-label::after {
    content: '—';
    margin: 0 1rem;
    color: #334155;
  }

  .client-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin: 0 auto 3rem;
  }

  .client-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    height: 70px;
    width: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .client-card:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.12);
  }

  .client-logo {
    max-width: 122px;
    max-height: 45px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(100%) brightness(1.5);
    opacity: 0.6;
    transition: all 0.3s ease;
  }

  .cl--brusa { max-width: 95px; }
  .cl--jr { max-width: 150px; }
  .cl--weber { max-width: 105px; }
  .cl--trend { max-width: 115px; }
  .cl--iac { max-width: 105px; }
  .cl--yanfeng { max-width: 200px; max-height: 100px; }

  .client-card:hover .client-logo {
    opacity: 0.9;
  }

  .transition-text {
    text-align: center;
    font-size: 1.1rem;
    color: #8791a1;
    margin: 3rem 0;
    line-height: 1.6;
  }

  .transition-text em {
    color: #d6dae0;
    font-style: italic;
  }

  .oem-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }

  .oem-logo {
    width: auto;
    height: 28px;
    object-fit: contain;
    filter: grayscale(100%) brightness(1.5);
    opacity: 0.5;
    transition: all 0.3s ease;
  }

  .oem-logo--mercedes { height: 46px; }
  .oem-logo--porsche { height: 22px; }
  .oem-logo--fischer { height: 30px; }
  .oem-logo--festool { height: 20px; }
  .oem-logo--bmw { height: 38px; }

  .oem-logo:hover {
    opacity: 0.8;
  }

  .divider {
    width: 1px;
    height: 30px;
    background: rgba(255,255,255,0.15);
  }

  @media (max-width: 768px) {
    .client-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .oem-row {
      flex-wrap: wrap;
      gap: 1.5rem;
    }

    .divider {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .client-grid {
      grid-template-columns: 1fr;
    }

    .client-logo {
      max-width: 100px;
    }
  }
</style>
