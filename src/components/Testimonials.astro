---
import { getEntry } from 'astro:content';

interface Props { locale?: string; }
const { locale = 'de' } = Astro.props;

const headlineData = await getEntry('pages', `${locale}/testimonials-headline`);
const { headline: testimonialsHeadline, testimonials } = headlineData?.data ?? {};
---

<section id="referenzen" class="testimonials-section">
  <div class="container">
    <h2 class="testimonials-headline">{testimonialsHeadline}</h2>
    <div class="testimonials-grid">
      {(testimonials ?? []).map((t: any, i: number) => (
        <div class={`testimonial-card testimonial-card--${i === 0 ? 'cyan' : i === 1 ? 'purple' : 'orange'}`}>
          <div class="stars">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <p class="quote-text">"{t.quote}"</p>
          <div class="quote-author">
            <img src={t.photo} alt={t.name} class="author-avatar" />
            <div class="author-info">
              <div class="author-name">{t.name}</div>
              <div class="author-position">{t.position}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    background: #f6f7f8;
    padding: 5rem 0;
  }

  .testimonials-headline {
    text-align: center;
    font-size: clamp(1.75rem, 3vw, 2rem);
    font-weight: 700;
    color: #1b222c;
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .testimonial-card {
    position: relative;
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.8);
    border-radius: 20px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 4px 24px rgba(0,0,0,0.04);
  }

  .testimonial-card::before {
    content: '';
    position: absolute;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0.5;
    pointer-events: none;
    transition: opacity 0.3s ease;
    top: -50px;
    right: -50px;
  }

  .testimonial-card--cyan::before {
    background: radial-gradient(circle, #3AA6B9 0%, transparent 70%);
  }

  .testimonial-card--purple::before {
    background: radial-gradient(circle, #4B5F78 0%, transparent 70%);
  }

  .testimonial-card--orange::before {
    background: radial-gradient(circle, #d99726 0%, transparent 70%);
  }

  .testimonial-card:hover {
    background: rgba(255,255,255,0.8);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }

  .testimonial-card:hover::before {
    opacity: 0.7;
  }

  .stars {
    position: relative;
    display: flex;
    gap: 0.2rem;
    margin-bottom: 1.25rem;
    color: #AFDDE9;
  }

  .quote-text {
    position: relative;
    font-size: 0.95rem;
    line-height: 1.7;
    color: #4B5F78;
    flex-grow: 1;
    margin-bottom: 1.5rem;
  }

  .quote-author {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .author-name {
    font-weight: 700;
    font-size: 0.9rem;
    color: #1b222c;
  }

  .author-position {
    font-size: 0.75rem;
    color: #4B5F78;
    line-height: 1.4;
  }

  @media (max-width: 1024px) {
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .testimonials-section {
      padding: 3rem 0;
    }
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
