---
import { getEntry } from 'astro:content';

interface Props { locale?: string; }
const { locale = 'de' } = Astro.props;

const foundersData = await getEntry('pages', `${locale}/founders`);
const { headline_highlight, headline_plain, subline, founders } = foundersData?.data ?? {};
---
<section class="founders-section">
  <div class="container">
    <div class="founders-header">
      <h2 class="founders-headline">
        <span class="highlight">{headline_highlight}</span><br />
        {headline_plain}
      </h2>
      <p class="founders-subline">{subline}</p>
    </div>

    {(founders ?? []).map((founder: any, i: number) => (
      <div class={`founder-row${i === 1 ? ' founder-row--reverse' : ''}`}>
        <div class="founder-photo">
          <img src={founder.photo} alt={founder.name} class="founder-img" />
        </div>
        <div class="founder-content">
          <div class="founder-name">{founder.name}</div>
          <div class="founder-role">{founder.role}</div>
          {(founder.manifesto ?? []).map((paragraph: string) => (
            <p class="founder-manifesto">{paragraph}</p>
          ))}
          <div class="founder-tags">
            {(founder.tags ?? []).map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .founders-section {
    background: #11161d;
    padding: 6rem 0;
  }

  .founders-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .founders-headline {
    font-size: clamp(1.75rem, 3vw, 2rem);
    font-weight: 700;
    color: #d6dae0;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin-bottom: 1.5rem;
  }

  .founders-headline .highlight {
    color: #AFDDE9;
    display: block;
  }

  .founders-subline {
    font-size: 1.1rem;
    color: #4B5F78;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .founder-row {
    display: grid;
    grid-template-columns: 30% 70%;
    gap: 4rem;
    align-items: center;
    margin-bottom: 6rem;
  }

  .founder-row:last-child {
    margin-bottom: 0;
  }

  .founder-row--reverse {
    grid-template-columns: 70% 30%;
  }

  .founder-row--reverse .founder-photo {
    order: 2;
  }

  .founder-row--reverse .founder-content {
    order: 1;
  }

  .founder-photo {
    display: flex;
    justify-content: center;
    position: relative;
  }

  /* Geometric accent shape behind photo */
  .founder-photo::before {
    content: '';
    position: absolute;
    width: 210px;
    height: 270px;
    border-radius: 16px;
    background: linear-gradient(135deg, #3AA6B9, #4B5F78);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) translate(18px, 18px);
    z-index: 0;
    opacity: 0.85;
  }

  /* Soft colored glow */
  .founder-photo::after {
    content: '';
    position: absolute;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(58,166,185,0.35) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
    filter: blur(18px);
    pointer-events: none;
  }

  /* Mirror the accent for the reversed row */
  .founder-row--reverse .founder-photo::before {
    transform: translate(-50%, -50%) translate(-18px, 18px);
    background: linear-gradient(225deg, #3AA6B9, #4B5F78);
  }

  .founder-img {
    width: 100%;
    max-width: 240px;
    aspect-ratio: 3/4;
    object-fit: cover;
    border-radius: 16px;
    border: 1px solid rgba(175,221,233,0.2);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    position: relative;
    z-index: 1;
  }

  .founder-content {
    max-width: 520px;
  }

  .founder-row--reverse .founder-content {
    margin-left: auto;
  }

  .founder-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.25rem;
  }

  .founder-role {
    font-size: 0.875rem;
    color: #4B5F78;
    margin-bottom: 1.5rem;
  }

  .founder-manifesto {
    font-size: 1.05rem;
    color: #8791a1;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .founder-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: #AFDDE9;
    background: rgba(175,221,233,0.08);
    border: 1px solid rgba(175,221,233,0.12);
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
  }

  @media (max-width: 900px) {
    .founder-row,
    .founder-row--reverse {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .founder-row--reverse .founder-photo,
    .founder-row--reverse .founder-content {
      order: unset;
    }

    .founder-content {
      max-width: 100%;
    }

    .founder-row--reverse .founder-content {
      margin-left: 0;
    }

    .founder-tags {
      justify-content: center;
    }

    .founder-img {
      max-width: 280px;
    }
  }

  @media (max-width: 640px) {
    .founders-section {
      padding: 4rem 0;
    }

    .founders-header {
      margin-bottom: 3rem;
    }

    .founder-row {
      margin-bottom: 4rem;
    }
  }
</style>
