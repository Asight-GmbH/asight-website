---
---
<div class="preloader">
  <div class="preloader__inner">
    <div class="preloader__logo">
      <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
        <g transform="translate(-103.28143,57.517413)">
          <path d="m 177.14436,248.75554 223.12186,-213.267776 -7.95467,66.154866 -16.76128,11.80441 2.96856,-26.745466 z" />
          <path d="M 183.22783,248.93865 422.57113,80.297815 406.37205,149.8996 390.71553,156.95278 395.37929,129.483 Z" />
          <path d="m 373.1294,141.96112 -1.42497,23.73104 10.58148,-4.84563 4.74932,-26.70388 z" />
          <path d="m 188.86185,249.47741 240.55666,-110.85842 -37.00676,110.6392 10.09023,-74.50174 z" />
          <path d="m 385.83501,180.42171 -7.51556,68.60396 19.79213,-72.76922 z" />
          <path d="m 370.92775,185.77391 -4.82293,63.7035 12.44488,-66.425 z" />
        </g>
      </svg>
    </div>
    <div class="preloader__bar-wrap">
      <div class="preloader__bar-track">
        <div class="preloader__bar-fill"></div>
      </div>
      <span class="preloader__bar-pct">0%</span>
    </div>
  </div>
</div>

<style>
  .preloader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #293353;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform, border-radius;
  }

  .preloader__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 26px;
  }

  .preloader__logo svg {
    width: 160px;
    height: auto;
    display: block;
  }

  /* Logo-Farben (Dark-Background-Palette) */
  .preloader__logo svg path:nth-child(1) { fill: rgba(69, 79, 94, 0.6); }
  .preloader__logo svg path:nth-child(2) { fill: rgba(63, 167, 181, 0.7); }
  .preloader__logo svg path:nth-child(3) { fill: rgba(69, 79, 94, 0.8); }
  .preloader__logo svg path:nth-child(4) { fill: rgba(167, 211, 221, 0.85); }
  .preloader__logo svg path:nth-child(5) { fill: #3fa7b5; }
  .preloader__logo svg path:nth-child(6) { fill: rgba(69, 79, 94, 0.9); }

  /* Animation 1 — Draw Reveal (Logo) */
  .preloader__logo svg path {
    opacity: 0;
    animation: pathReveal 0.48s ease-out forwards;
  }

  .preloader__logo svg path:nth-child(1) { animation-delay: 0.04s; }
  .preloader__logo svg path:nth-child(2) { animation-delay: 0.26s; }
  .preloader__logo svg path:nth-child(3) { animation-delay: 0.48s; }
  .preloader__logo svg path:nth-child(4) { animation-delay: 0.70s; }
  .preloader__logo svg path:nth-child(5) { animation-delay: 0.92s; }
  .preloader__logo svg path:nth-child(6) { animation-delay: 1.14s; }

  @keyframes pathReveal {
    from {
      opacity: 0;
      transform: translateX(-7px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }

  /* Animation 2 — Progress Bar */
  .preloader__bar-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    opacity: 0;
    animation: barAppear 0.25s ease-out 0.04s forwards;
  }

  @keyframes barAppear {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .preloader__bar-track {
    width: 160px;
    height: 2px;
    border-radius: 2px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.10);
  }

  .preloader__bar-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #3aa2b9, #5bb3c7);
    border-radius: 2px;
    animation: barFill 1.62s cubic-bezier(0.25, 0.1, 0.25, 1) 0.04s forwards;
  }

  @keyframes barFill {
    0%   { width: 0%;   }
    100% { width: 100%; }
  }

  .preloader__bar-pct {
    font-family: 'DM Mono', 'JetBrains Mono', monospace;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.1em;
  }

  /* Animation 3 — Exit (Clean slide up) */
  .preloader.is-exiting {
    animation: preloaderExit 0.8s cubic-bezier(0.65, 0, 0.35, 1) forwards;
  }

  @keyframes preloaderExit {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-100%);
    }
  }
</style>

<script>
  const preloader = document.querySelector('.preloader');

  // Scroll immer nach oben bei Seitenstart
  window.scrollTo(0, 0);
  document.body.style.overflow = 'hidden';

  if (sessionStorage.getItem('preloader-shown')) {
    preloader?.remove();
    document.body.style.overflow = '';
  } else {
    sessionStorage.setItem('preloader-shown', '1');

    const pct = document.querySelector('.preloader__bar-pct');
    let start: number | null = null;
    const duration = 1620;
    const delay = 40;

    setTimeout(() => {
      requestAnimationFrame(function tick(ts: number) {
        if (!start) start = ts;
        const progress = Math.min((ts - start) / duration, 1);
        const eased = progress < 0.5
          ? 2 * progress * progress
          : 1 - Math.pow(-2 * progress + 2, 2) / 2;
        if (pct) pct.textContent = Math.round(eased * 100) + '%';
        if (progress < 1) requestAnimationFrame(tick);
      });
    }, delay);

    setTimeout(() => {
      preloader?.classList.add('is-exiting');
      preloader?.addEventListener('animationend', () => {
        preloader?.remove();
        document.body.style.overflow = '';
        window.scrollTo(0, 0);
      }, { once: true });
    }, 2260);
  }
</script>
